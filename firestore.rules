rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 0. HELPERS ---
    
    function auth() { return request.auth != null; }
    
    function isMember(shopId) {
      return auth() && exists(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid));
    }
    
    function isAdmin(shopId) {
      return isMember(shopId) && get(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid)).data.role == 'admin';
    }

    // Granular permission check
    function can(shopId, module, action) {
      let claim = request.auth.token;
      let hasClaim = claim.shopId == shopId && module in claim.perms && claim.perms[module][action] != null;
      let staffData = get(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid)).data;
      let dbPerm = staffData.get('permissions', {}).get(module, {}).get(action, false);
      
      return auth() && (
        hasClaim || 
        staffData.role == 'admin' || 
        dbPerm == true || (dbPerm is map && dbPerm.max != null)
      );
    }

    // Validate 'override_price' discount limits
    function isValidDiscount(shopId, discountVal) {
      if (discountVal <= 0) return true;
      let claim = request.auth.token;
      let staffData = get(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid)).data;
      let hasClaim = claim.shopId == shopId && 'sales' in claim.perms && 'override_price' in claim.perms.sales;
      let perm = hasClaim ? claim.perms.sales.override_price : staffData.get('permissions', {}).get('sales', {}).get('override_price', false);
      
      return staffData.role == 'admin' || perm == true || (perm is map && perm.max != null && discountVal <= perm.max);
    }

    // --- 1. SHOP HIERARCHY ---

    match /shops/{shopId} {
      allow read: if isMember(shopId);
      allow write: if isAdmin(shopId);

      // Inventory
      match /inventory/{item} {
        allow read: if can(shopId, 'inventory', 'view');
        allow create: if can(shopId, 'inventory', 'create');
        allow update: if can(shopId, 'inventory', 'edit');
        allow delete: if can(shopId, 'inventory', 'delete');
      }
      
      // Cost Data
      match /inventory_private/{item} {
        allow read: if can(shopId, 'inventory', 'view_cost');
        allow write: if isAdmin(shopId);
      }
      
      // Sales
      match /sales/{sale} {
        allow read: if can(shopId, 'sales', 'view');
        allow create: if can(shopId, 'sales', 'create') && isValidDiscount(shopId, request.resource.data.get('discount', 0));
        allow update: if isAdmin(shopId);
        allow delete: if can(shopId, 'sales', 'void_sale');
      }
      
      // Customers
      match /customers/{cust} {
        allow read: if can(shopId, 'customers', 'view');
        allow write: if can(shopId, 'customers', 'edit') || can(shopId, 'customers', 'create');
        allow delete: if can(shopId, 'customers', 'delete');
      }

      // Expenses
      match /expenses/{exp} {
        allow read: if can(shopId, 'expenses', 'view');
        allow create: if can(shopId, 'expenses', 'create');
        allow delete: if can(shopId, 'expenses', 'delete');
      }

      // Staff (Split Write: Self-update vs Admin)
      match /staff/{member} {
        allow read: if isMember(shopId) || can(shopId, 'team', 'view');
        allow create, delete: if isAdmin(shopId);
        allow update: if isAdmin(shopId) || (
          auth() && request.auth.uid == member && 
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions', 'salary'])
        );
      }
      
      match /staff_private/{member} {
        allow read, write: if isAdmin(shopId);
      }

      // Attendance
      match /attendance/{at} {
        allow read: if isMember(shopId);
        allow write: if isAdmin(shopId) || (auth() && request.auth.uid == request.resource.data.staffId);
      }

      // Invitations
      match /invitations/{invite} {
        allow read, write: if isAdmin(shopId);
      }

      // Private Vault (Strictly blocked for all client direct access)
      match /private/{doc=**} {
        allow read, write: if false; 
      }
    }

    // --- 2. GLOBAL USER PROFILES ---

    match /users/{userId} {
      allow read: if auth();
      allow write: if auth() && request.auth.uid == userId;
    }
  }
}
